# user.toml — per-user, cross-session state for the marky-skills plugin
#
# WHY THIS FILE EXISTS
# Skills and agents are amnesiac: each session starts with no memory of the last
# one. This file is the small bit of durable state that survives between
# sessions so the marky-api skill can (1) ask you for feedback on a cadence
# instead of every single time, and (2) notice when you have built or improved a
# skill and offer to contribute it back to the Marky community.
#
# WHERE IT LIVES
# Next to this example, in the plugin / skill install directory — i.e. the
# directory that holds `user.toml.example`. The marky-api skill reads and writes
# it RELATIVE TO ITS OWN LOCATION, so the same logic works for a cloned repo
# (the repo root) and for an installed plugin copy (`${CLAUDE_PLUGIN_ROOT}`).
#
# IT IS GITIGNORED ON PURPOSE
# The real `user.toml` is your local state. It is in `.gitignore` so a
# contributor's personal cadence/prefs never get committed. Copy this file to
# `user.toml` (or let the skill create it for you with sensible defaults on
# first run) and edit the values to taste.
#
# To opt out of either prompt entirely, set its `on` value to `off`.

[feedback]
# leave_feedback: "on" | "off"
#   "on"  → the skill prompts you for feedback on the cadence below.
#   "off" → no cadence prompts. (Immediate bug/friction feedback is always sent
#           regardless of this setting — that is separate from the cadence.)
leave_feedback = "on"

# How long to wait between feedback prompts. Plain duration like "3 weeks",
# "10 days", "1 month". The skill parses it to compute the next prompt time.
ask_feedback_interval = "3 weeks"

# ISO 8601 UTC timestamp of the NEXT time the skill should prompt for feedback.
# On first run the skill sets this to now + ask_feedback_interval. After each
# prompt (Yes or No) it bumps this forward by one interval.
ask_feedback_next = "2026-07-21T15:44:00Z"

[contribution]
# suggest_contribution: "on" | "off"
#   "on"  → the skill checks for new/improved skills and may offer to help you
#           contribute them back to the community repo.
#   "off" → never offer. (Set by choosing "Don't ask again" at the prompt.)
suggest_contribution = "on"

# ISO 8601 UTC timestamp of the NEXT time the skill may offer the contribution
# nudge. Bumped forward by a cooldown after each ask.
ask_contribution_next = "2026-07-07T00:00:00Z"

[meta]
# Bump this if the schema changes so the skill can migrate older files.
schema_version = 1
